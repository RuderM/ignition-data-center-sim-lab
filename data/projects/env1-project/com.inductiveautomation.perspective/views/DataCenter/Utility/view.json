{
  "custom": {},
  "params": {
    "baseTagPath": "[T1]MBT1/UTL1"
  },
  "propConfig": {
    "params.baseTagPath": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 920,
      "width": 1600
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "screenTitle"
            },
            "props": {
              "style": {
                "classes": "sg/heading",
                "fontSize": "3.2rem",
                "overflow": "hidden",
                "overflowWrap": "break-word",
                "whiteSpace": "normal"
              },
              "text": "Utility Overview"
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "boundDevice"
                },
                "position": {
                  "basis": "340px",
                  "grow": 1
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "\"Bound Device: \" + {view.params.baseTagPath}"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "sg/muted",
                    "fontSize": "0.9rem",
                    "fontWeight": "700",
                    "overflow": "hidden",
                    "textOverflow": "ellipsis",
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "headerDetails"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "justify": "space-between",
              "style": {
                "gap": "12px",
                "overflow": "visible"
              },
              "wrap": "wrap"
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "overallStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") \u003d false, \"sg/statusDanger\", if(tag({view.params.baseTagPath} + \"/Status/Faulted\") \u003d true, \"sg/statusDanger\", if(tag({view.params.baseTagPath} + \"/Status/Available\") \u003d false, \"sg/statusWarning\", \"sg/statusGood\")))"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") \u003d false, \"Overall: COMM LOSS\", if(tag({view.params.baseTagPath} + \"/Status/Faulted\") \u003d true, \"Overall: FAULTED\", if(tag({view.params.baseTagPath} + \"/Status/Available\") \u003d false, \"Overall: UNAVAILABLE\", \"Overall: NORMAL\")))"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "availableStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Available\") \u003d true, \"sg/statusGood\", \"sg/statusWarning\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Available\") \u003d true, \"Available: YES\", \"Available: NO\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "communicationStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") \u003d true, \"sg/statusGood\", \"sg/statusDanger\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") \u003d true, \"Communication: GOOD\", \"Communication: LOSS\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "faultStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Faulted\") \u003d true, \"sg/statusDanger\", \"sg/statusGood\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Faulted\") \u003d true, \"Fault State: ACTIVE\", \"Fault State: NONE\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "statusPills"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "style": {
                "gap": "12px",
                "overflow": "visible"
              },
              "wrap": "wrap"
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "header"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "sg/hero",
            "gap": "18px",
            "overflow": "visible"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "summaryEyebrow"
            },
            "position": {
              "basis": "180px",
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "sg/eyebrow"
              },
              "text": "SITE POWER SUMMARY"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "summaryStatement"
            },
            "position": {
              "basis": "520px",
              "grow": 1
            },
            "props": {
              "style": {
                "color": "#16213e",
                "fontSize": "1.1rem",
                "fontWeight": "600",
                "overflowWrap": "break-word",
                "whiteSpace": "normal"
              },
              "text": "Utility_1 is supplying MBT1 and feeding downstream main switchgear MSG_1."
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "deviceMetadata"
            },
            "position": {
              "basis": "420px",
              "grow": 1
            },
            "props": {
              "style": {
                "classes": "sg/muted",
                "fontSize": "0.95rem",
                "fontWeight": "700",
                "overflow": "hidden",
                "textOverflow": "ellipsis",
                "whiteSpace": "nowrap"
              },
              "text": "Manufacturer: GridSim Industries   Model: GS-13K8-01-SIM"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "sitePowerSummary"
        },
        "position": {
          "display": false,
          "shrink": 0
        },
        "props": {
          "justify": "space-between",
          "style": {
            "classes": "sg/panel",
            "gap": "22px",
            "overflow": "visible"
          },
          "wrap": "wrap"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "liveElectricalHeading"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "classes": "sg/heading",
            "fontSize": "1.55rem"
          },
          "text": "Live Electrical Values"
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "voltageCard"
            },
            "position": {
              "basis": "335px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Electrical/VoltageLLAvg\") / 15000 * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if(tag({view.params.baseTagPath} + \"/Electrical/VoltageLLAvg\") \u003c 12420, \"Warning\", \"Good\")"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Electrical/VoltageLLAvg\") / 1000, \"0.0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Average incoming line-to-line voltage",
                "label": "Voltage",
                "unit": " kV"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "currentCard"
            },
            "position": {
              "basis": "335px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Electrical/CurrentAvg\") / 2000 * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Electrical/CurrentAvg\"), \"0.0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Average utility current",
                "label": "Current",
                "status": "Good",
                "unit": " A"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "frequencyCard"
            },
            "position": {
              "basis": "335px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "(tag({view.params.baseTagPath} + \"/Electrical/Frequency\") - 55) / 10 * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if(tag({view.params.baseTagPath} + \"/Electrical/Frequency\") \u003c 59.5, \"Warning\", if(tag({view.params.baseTagPath} + \"/Electrical/Frequency\") \u003e 60.5, \"Warning\", \"Good\"))"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Electrical/Frequency\"), \"0.0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Incoming utility frequency",
                "label": "Frequency",
                "unit": " Hz"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "realPowerCard"
            },
            "position": {
              "basis": "335px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Power/RealPower\") / 2000 * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Power/RealPower\"), \"#,##0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Total real power supplied by the utility",
                "label": "Real Power",
                "status": "Good",
                "unit": " kW"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "apparentPowerCard"
            },
            "position": {
              "basis": "335px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Power/ApparentPower\") / 2200 * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Power/ApparentPower\"), \"#,##0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Total apparent power supplied by the utility",
                "label": "Apparent Power",
                "status": "Good",
                "unit": " kVA"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "powerFactorCard"
            },
            "position": {
              "basis": "335px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Power/PowerFactor\") * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if(tag({view.params.baseTagPath} + \"/Power/PowerFactor\") \u003c 0.9, \"Warning\", \"Good\")"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Power/PowerFactor\"), \"0.00\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Utility power factor",
                "label": "Power Factor",
                "unit": ""
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "totalEnergyCard"
            },
            "position": {
              "basis": "335px",
              "grow": 1
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Energy/TotalEnergy\"), \"#,##0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Accumulated utility energy consumption",
                "label": "Total Energy",
                "progress": 0,
                "status": "Good",
                "unit": " kWh"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "utilityLoadCard"
            },
            "position": {
              "basis": "335px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Capacity/LoadPct\")"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if(tag({view.params.baseTagPath} + \"/Capacity/LoadPct\") \u003e\u003d 100, \"Danger\", if(tag({view.params.baseTagPath} + \"/Capacity/LoadPct\") \u003e\u003d 85, \"Warning\", \"Good\"))"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Capacity/LoadPct\"), \"0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Utility apparent power as a percentage of rated power",
                "label": "Utility Load",
                "unit": "%"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          }
        ],
        "meta": {
          "name": "metricGrid"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "gap": "18px",
            "overflow": "visible"
          },
          "wrap": "wrap"
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "trendHeading"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "sg/heading",
                "fontSize": "1.55rem"
              },
              "text": "Recent Power Trend"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "trendSubheading"
            },
            "props": {
              "style": {
                "classes": "sg/muted",
                "fontSize": "0.95rem",
                "overflowWrap": "break-word",
                "whiteSpace": "normal"
              },
              "text": "Real power demand normalized to the 2,000 kW utility service range."
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "currentRealPower"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Current real power: \" + numberFormat(tag({view.params.baseTagPath} + \"/Power/RealPower\"), \"#,##0\") + \" kW\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "sg/metricValue",
                "fontSize": "2.4rem",
                "overflow": "hidden",
                "textOverflow": "ellipsis",
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "realPowerCapacityProgress"
            },
            "position": {
              "basis": "14px",
              "shrink": 0
            },
            "propConfig": {
              "props.value": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Power/RealPower\") / 2000 * 100"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "bar": {
                "color": "#2f80ed"
              },
              "style": {
                "height": "14px"
              },
              "track": {
                "color": "#d9e2ef"
              }
            },
            "type": "ia.display.progress"
          }
        ],
        "meta": {
          "name": "recentPowerTrend"
        },
        "position": {
          "basis": "240px",
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "sg/panel",
            "gap": "16px",
            "overflow": "visible"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "utilityPage"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "sg/page",
        "gap": "22px",
        "minHeight": "100vh"
      }
    },
    "type": "ia.container.flex"
  }
}