                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Alarms/Overtemperature\") = true, \"sg/statusDanger\", \"sg/statusGood\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Alarms/Overtemperature\") = true, \"Overtemperature: ACTIVE\", \"Overtemperature: CLEAR\")"
