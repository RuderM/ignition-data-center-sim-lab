                  "type": "expr"
                }
              },
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Electrical/PrimaryVoltageLLAvg\") / 480 * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.trendTagPath": {
                "binding": {
                  "config": {
                    "expression": "{view.params.baseTagPath} + \"/Electrical/PrimaryVoltageLLAvg\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Average transformer primary line-to-line voltage",
                "label": "Primary Voltage",
                "status": "Good",
                "unit": " V",
                "trendLabel": "Primary Voltage",
                "trendUnit": "V"
