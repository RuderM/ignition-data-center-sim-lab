                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") = true, \"sg/statusGood\", \"sg/statusDanger\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") = true, \"Communication: GOOD\", \"Communication: LOSS\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "faultStatus"
