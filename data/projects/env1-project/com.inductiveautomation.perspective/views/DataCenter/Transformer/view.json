                "helperText": "Configured transformer nameplate capacity",
                "label": "Rated Power",
                "status": "Good",
                "unit": " kVA"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "loadPctCard"
            },
            "position": {
              "basis": "260px",
              "grow": 1
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Capacity/LoadPct\"), \"0\")"
                  },
                  "type": "expr"
                }
              },
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Capacity/LoadPct\")"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if(tag({view.params.baseTagPath} + \"/Capacity/LoadPct\") >= 100, \"Danger\", if(tag({view.params.baseTagPath} + \"/Capacity/LoadPct\") >= 85, \"Warning\", \"Good\"))"
                  },
                  "type": "expr"
                }
              },
              "props.params.trendTagPath": {
                "binding": {
                  "config": {
                    "expression": "{view.params.baseTagPath} + \"/Capacity/LoadPct\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Apparent power as a percentage of rated capacity",
                "label": "Transformer Load",
                "status": "Good",
                "unit": "%",
                "trendLabel": "Transformer Load",
                "trendUnit": "%"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          }
        ],
        "meta": {
          "name": "metricGrid"
        },
        "props": {
          "alignContent": "flex-start",
          "style": {
            "gap": "18px",
            "overflow": "visible"
          },
          "wrap": "wrap"
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "trendHeading"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "sg/heading",
                "fontSize": "1.35rem"
              },
              "text": "Transformer Load"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "trendSubheading"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "sg/muted",
                "fontSize": "0.95rem"
              },
              "text": "Current apparent power and utilization from live transformer UDT values."
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "currentLoad"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "\"Current apparent power: \" + numberFormat(tag({view.params.baseTagPath} + \"/Power/ApparentPower\"), \"#,##0\") + \" kVA\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "color": "#16213e",
                "fontSize": "1.1rem",
                "fontWeight": "700"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "loadProgress"
            },
            "position": {
              "basis": "14px",
              "shrink": 0
            },
            "propConfig": {
              "props.value": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Capacity/LoadPct\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "bar": {
                "color": "#2f80ed"
              },
              "style": {
                "height": "14px"
              },
              "track": {
                "color": "#d9e2ef"
              }
            },
            "type": "ia.display.progress"
          }
        ],
        "meta": {
          "name": "loadTrendPanel"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "sg/panel",
            "gap": "14px",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "transformerPage"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "sg/page",
        "gap": "24px",
        "minHeight": "100vh"
      }
    },
    "type": "ia.container.flex"
  }
}
