                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") = false, \"sg/statusDanger\", if(tag({view.params.baseTagPath} + \"/Status/Faulted\") = true, \"sg/statusDanger\", if(tag({view.params.baseTagPath} + \"/Status/Available\") = false, \"sg/statusWarning\", if(tag({view.params.baseTagPath} + \"/Alarms/Overtemperature\") = true || tag({view.params.baseTagPath} + \"/Alarms/Overload\") = true, \"sg/statusWarning\", \"sg/statusGood\"))))"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") = false, \"Overall: COMM LOSS\", if(tag({view.params.baseTagPath} + \"/Status/Faulted\") = true, \"Overall: FAULTED\", if(tag({view.params.baseTagPath} + \"/Status/Available\") = false, \"Overall: UNAVAILABLE\", if(tag({view.params.baseTagPath} + \"/Alarms/Overtemperature\") = true || tag({view.params.baseTagPath} + \"/Alarms/Overload\") = true, \"Overall: ALARM\", \"Overall: NORMAL\"))))"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "availableStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Available\") = true, \"sg/statusGood\", \"sg/statusWarning\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Available\") = true, \"Available: YES\", \"Available: NO\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
