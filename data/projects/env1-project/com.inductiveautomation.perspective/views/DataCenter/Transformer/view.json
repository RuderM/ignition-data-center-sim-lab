                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Faulted\") = true, \"sg/statusDanger\", \"sg/statusGood\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Faulted\") = true, \"Fault State: ACTIVE\", \"Fault State: NONE\")"
