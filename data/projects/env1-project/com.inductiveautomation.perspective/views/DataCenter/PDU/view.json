{
  "custom": {},
  "params": {
    "baseTagPath": "[T1]MBT1/Utility1/MSG1/PDU1/PDU"
  },
  "propConfig": {
    "params.baseTagPath": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 920,
      "width": 1600
    }
  },
