          "alignItems": "center",
          "justify": "space-between",
          "style": {
            "classes": "sg/panel",
            "gap": "18px",
            "overflow": "hidden"
          },
          "wrap": "wrap"
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "liveElectricalHeading"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "classes": "sg/eyebrow"
          },
          "text": "Live Electrical Metrics"
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "inputVoltageCard"
            },
            "position": {
              "basis": "260px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Electrical/InputVoltageLLAvg\") / 480 * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Electrical/InputVoltageLLAvg\"), \"#,##0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Average PDU input line-to-line voltage",
                "label": "Input Voltage",
                "status": "Good",
                "unit": " V"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "outputVoltageCard"
            },
            "position": {
              "basis": "260px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Electrical/OutputVoltageLLAvg\") / 208 * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if(tag({view.params.baseTagPath} + \"/Electrical/OutputVoltageLLAvg\") \u003c 187, \"Warning\", \"Good\")"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Electrical/OutputVoltageLLAvg\"), \"#,##0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Average output line-to-line voltage after transformation",
                "label": "Output Voltage",
                "unit": " V"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "outputCurrentCard"
            },
            "position": {
              "basis": "260px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Electrical/OutputCurrentAvg\") / 700 * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Electrical/OutputCurrentAvg\"), \"#,##0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Average PDU output current from active ways",
                "label": "Output Current",
                "status": "Good",
                "unit": " A"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "temperatureCard"
            },
            "position": {
              "basis": "260px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "(tag({view.params.baseTagPath} + \"/Temperature/EnclosureTemp\") + 20) / 120 * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if(tag({view.params.baseTagPath} + \"/Temperature/EnclosureTemp\") \u003e\u003d 50, \"Danger\", if(tag({view.params.baseTagPath} + \"/Temperature/EnclosureTemp\") \u003e\u003d 45, \"Warning\", \"Good\"))"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Temperature/EnclosureTemp\"), \"0.0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "PDU enclosure temperature",
                "label": "Enclosure Temp",
                "unit": " degC"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "realPowerCard"
            },
            "position": {
              "basis": "260px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Power/RealPower\") / tag({view.params.baseTagPath} + \"/Capacity/RatedPower\") * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Power/RealPower\"), \"#,##0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Total real power from active PDU ways",
                "label": "Real Power",
                "status": "Good",
                "unit": " kW"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "apparentPowerCard"
