            "position": {
              "basis": "260px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Power/ApparentPower\") / tag({view.params.baseTagPath} + \"/Capacity/RatedPower\") * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Power/ApparentPower\"), \"#,##0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Total apparent power from active PDU ways",
                "label": "Apparent Power",
                "status": "Good",
                "unit": " kVA"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "powerFactorCard"
            },
            "position": {
              "basis": "260px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "tag({view.params.baseTagPath} + \"/Power/PowerFactor\") * 100"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if(tag({view.params.baseTagPath} + \"/Power/PowerFactor\") \u003c 0.9, \"Warning\", \"Good\")"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Power/PowerFactor\"), \"0.00\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "PDU aggregate power factor",
                "label": "Power Factor",
                "unit": ""
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "totalEnergyCard"
            },
            "position": {
              "basis": "260px",
              "grow": 1
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Energy/TotalEnergy\"), \"#,##0\")"
