              "text": "PDU1 is fed from MSG1 and supplies transformed downstream output bus ways for remote load distribution."
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "deviceMetadata"
            },
            "position": {
              "basis": "430px",
              "grow": 1
            },
            "props": {
              "style": {
                "classes": "sg/muted",
                "fontSize": "0.95rem",
                "fontWeight": "700",
                "overflow": "hidden",
                "textOverflow": "ellipsis",
                "whiteSpace": "nowrap"
              },
              "text": "Manufacturer: Vertiv   Model: PowerBoard-PDU-480-4W-SIM"
            },
            "type": "ia.display.label"
          }
