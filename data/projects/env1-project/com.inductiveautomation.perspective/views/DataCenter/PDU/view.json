              },
              "text": "DISTRIBUTION DETAIL"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "screenTitle"
            },
            "props": {
              "style": {
                "classes": "sg/heading",
                "fontSize": "3.2rem",
                "overflow": "hidden",
                "overflowWrap": "break-word",
                "whiteSpace": "normal"
              },
              "text": "Power Distribution Unit"
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "boundDevice"
                },
                "position": {
                  "basis": "340px",
                  "grow": 1
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "\"Bound Device: \" + {view.params.baseTagPath}"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "sg/muted",
                    "fontSize": "0.9rem",
                    "fontWeight": "700",
                    "overflow": "hidden",
                    "textOverflow": "ellipsis",
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "headerDetails"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "justify": "space-between",
              "style": {
                "gap": "12px",
                "overflow": "visible"
              },
              "wrap": "wrap"
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "overallStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") \u003d false, \"sg/statusDanger\", if(tag({view.params.baseTagPath} + \"/Status/Faulted\") \u003d true, \"sg/statusDanger\", if(tag({view.params.baseTagPath} + \"/Status/Available\") \u003d false, \"sg/statusWarning\", \"sg/statusGood\")))"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") \u003d false, \"Overall: COMM LOSS\", if(tag({view.params.baseTagPath} + \"/Status/Faulted\") \u003d true, \"Overall: FAULTED\", if(tag({view.params.baseTagPath} + \"/Status/Available\") \u003d false, \"Overall: UNAVAILABLE\", \"Overall: NORMAL\")))"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "availableStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Available\") \u003d true, \"sg/statusGood\", \"sg/statusWarning\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Available\") \u003d true, \"Available: YES\", \"Available: NO\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "communicationStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") \u003d true, \"sg/statusGood\", \"sg/statusDanger\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/CommGood\") \u003d true, \"Communication: GOOD\", \"Communication: LOSS\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "faultStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Faulted\") \u003d true, \"sg/statusDanger\", \"sg/statusGood\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Status/Faulted\") \u003d true, \"Fault State: ACTIVE\", \"Fault State: NONE\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "inputBreakerStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Breaker/InputClosed\") \u003d true, \"sg/statusGood\", \"sg/statusWarning\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Breaker/InputClosed\") \u003d true, \"Input Breaker: CLOSED\", \"Input Breaker: OPEN\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "inputTripStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Breaker/InputTripped\") \u003d true, \"sg/statusDanger\", \"sg/statusGood\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Breaker/InputTripped\") \u003d true, \"Input Trip: ACTIVE\", \"Input Trip: CLEAR\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "overloadStatus"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.style.classes": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Alarms/Overload\") \u003d true, \"sg/statusDanger\", \"sg/statusGood\")"
                      },
                      "type": "expr"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "if(tag({view.params.baseTagPath} + \"/Alarms/Overload\") \u003d true, \"Overload: ACTIVE\", \"Overload: CLEAR\")"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "whiteSpace": "nowrap"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "statusPills"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "style": {
                "gap": "12px",
                "overflow": "visible"
              },
              "wrap": "wrap"
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "header"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "sg/hero",
            "gap": "18px",
            "overflow": "visible"
          }
        },
        "type": "ia.container.flex"
