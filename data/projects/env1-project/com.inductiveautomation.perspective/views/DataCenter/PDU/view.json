                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Accumulated PDU output energy",
                "label": "Total Energy",
                "progress": 0,
                "status": "Good",
                "unit": " kWh"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "ratedPowerCard"
            },
            "position": {
              "basis": "260px",
              "grow": 1
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat(tag({view.params.baseTagPath} + \"/Capacity/RatedPower\"), \"#,##0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Configured PDU output capacity",
                "label": "Rated Power",
                "progress": 0,
                "status": "Good",
                "unit": " kVA"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
