{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 960,
      "width": 1440
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "eyebrow"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "sg/eyebrow"
              },
              "text": "Gateway status"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "gatewayName"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "direct",
                    "publishInitial": true,
                    "tagPath": "[System]Gateway/SystemName"
                  },
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "classes": "sg/heading",
                "fontSize": "3.2rem",
                "overflow": "hidden",
                "overflowWrap": "break-word",
                "whiteSpace": "normal"
              }
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "licenseState"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "\"License: \" + {[System]Gateway/LicenseState}"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "sg/statusGood"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "redundancyRole"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "\"Role: \" + {[System]Gateway/Redundancy/Role}"
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "sg/statusGood"
                  }
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "uptime"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "expression": "\"Uptime: \" + toStr(floor({[System]Gateway/UptimeSeconds} / 86400)) + \"d \" + toStr(floor(({[System]Gateway/UptimeSeconds} - (floor({[System]Gateway/UptimeSeconds} / 86400) * 86400)) / 3600)) + \"h\""
                      },
                      "type": "expr"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "sg/statusGood"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "heroFacts"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "style": {
                "gap": "12px",
                "overflow": "visible"
              },
              "wrap": "wrap"
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "hero"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "sg/hero",
            "gap": "22px",
            "overflow": "visible"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "cpuCard"
            },
            "position": {
              "basis": "320px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "{[System]Gateway/Performance/CPU Usage}"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if({[System]Gateway/Performance/CPU Usage} \u003e\u003d 90, \"Danger\", if({[System]Gateway/Performance/CPU Usage} \u003e\u003d 70, \"Warning\", \"Good\"))"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat({[System]Gateway/Performance/CPU Usage}, \"0.0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "JVM-reported gateway CPU utilization",
                "label": "CPU usage",
                "unit": "%"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "memoryUtilizationCard"
            },
            "position": {
              "basis": "320px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "{[System]Gateway/Performance/Memory Utilization}"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if({[System]Gateway/Performance/Memory Utilization} \u003e\u003d 90, \"Danger\", if({[System]Gateway/Performance/Memory Utilization} \u003e\u003d 70, \"Warning\", \"Good\"))"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat({[System]Gateway/Performance/Memory Utilization}, \"0.0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Current memory usage divided by max memory",
                "label": "Memory utilization",
                "unit": "%"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "memoryUsedCard"
            },
            "position": {
              "basis": "320px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "{[System]Gateway/Performance/Memory Utilization}"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat({[System]Gateway/Performance/Memory Usage} / 1048576, \"0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Gateway memory currently in use",
                "label": "Memory used",
                "status": "Good",
                "unit": " MB"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "maxMemoryCard"
            },
            "position": {
              "basis": "320px",
              "grow": 1
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat({[System]Gateway/Performance/Max Memory} / 1048576, \"0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Configured JVM maximum memory",
                "label": "Max memory",
                "progress": 100,
                "status": "Good",
                "unit": " MB"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "diskCard"
            },
            "position": {
              "basis": "320px",
              "grow": 1
            },
            "propConfig": {
              "props.params.progress": {
                "binding": {
                  "config": {
                    "expression": "{[System]Gateway/Performance/Disk Utilization}"
                  },
                  "type": "expr"
                }
              },
              "props.params.status": {
                "binding": {
                  "config": {
                    "expression": "if({[System]Gateway/Performance/Disk Utilization} \u003e\u003d 90, \"Danger\", if({[System]Gateway/Performance/Disk Utilization} \u003e\u003d 70, \"Warning\", \"Good\"))"
                  },
                  "type": "expr"
                }
              },
              "props.params.value": {
                "binding": {
                  "config": {
                    "expression": "numberFormat({[System]Gateway/Performance/Disk Utilization}, \"0.0\")"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Percentage of hard disk currently in use",
                "label": "Disk utilization",
                "unit": "%"
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          },
          {
            "meta": {
              "name": "sessionsCard"
            },
            "position": {
              "basis": "320px",
              "grow": 1
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "direct",
                    "publishInitial": true,
                    "tagPath": "[System]Gateway/Sessions/SessionCount"
                  },
                  "type": "tag"
                }
              }
            },
            "props": {
              "params": {
                "helperText": "Active sessions on this gateway",
                "label": "Gateway sessions",
                "progress": 0,
                "status": "Good",
                "unit": ""
              },
              "path": "Shared/MetricCard",
              "style": {
                "height": "190px"
              }
            },
            "type": "ia.display.view"
          }
        ],
        "meta": {
          "name": "metricGrid"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "alignContent": "flex-start",
          "style": {
            "gap": "18px",
            "overflow": "visible"
          },
          "wrap": "wrap"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "gatewayStatusPage"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "sg/page",
        "gap": "24px",
        "minHeight": "100vh"
      }
    },
    "type": "ia.container.flex"
  }
}