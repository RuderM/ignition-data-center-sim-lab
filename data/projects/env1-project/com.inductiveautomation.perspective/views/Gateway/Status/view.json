{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "width": 1440,
      "height": 960
    }
  },
  "root": {
    "version": 0,
    "type": "ia.container.flex",
    "props": {
      "direction": "column",
      "wrap": "nowrap",
      "justify": "flex-start",
      "alignItems": "stretch",
      "alignContent": "stretch",
      "style": {
        "classes": "sg/page",
        "gap": "24px",
        "minHeight": "100vh",
        "overflow": "auto"
      }
    },
    "meta": {
      "name": "gatewayStatusPage"
    },
    "children": [
      {
        "version": 0,
        "type": "ia.container.flex",
        "props": {
          "direction": "column",
          "wrap": "nowrap",
          "justify": "flex-start",
          "alignItems": "stretch",
          "alignContent": "stretch",
          "style": {
            "classes": "sg/hero",
            "gap": "22px",
            "overflow": "visible"
          }
        },
        "meta": {
          "name": "hero"
        },
        "position": {
          "grow": 0,
          "shrink": 0,
          "basis": "auto"
        },
        "children": [
          {
            "version": 0,
            "type": "ia.display.label",
            "props": {
              "text": "Gateway status",
              "style": {
                "classes": "sg/eyebrow"
              }
            },
            "meta": {
              "name": "eyebrow"
            },
            "position": {
              "grow": 0,
              "shrink": 0,
              "basis": "auto"
            }
          },
          {
            "version": 0,
            "type": "ia.display.label",
            "props": {
              "text": "Ignition Gateway",
              "style": {
                "classes": "sg/heading",
                "fontSize": "3.2rem",
                "overflow": "hidden",
                "overflowWrap": "break-word",
                "whiteSpace": "normal"
              }
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "type": "tag",
                  "config": {
                    "mode": "direct",
                    "tagPath": "[System]Gateway/SystemName",
                    "fallbackDelay": 2.5,
                    "publishInitial": true
                  }
                }
              }
            },
            "meta": {
              "name": "gatewayName"
            },
            "position": {
              "grow": 0,
              "shrink": 1,
              "basis": "auto"
            }
          },
          {
            "version": 0,
            "type": "ia.container.flex",
            "props": {
              "direction": "row",
              "wrap": "wrap",
              "justify": "flex-start",
              "alignItems": "center",
              "alignContent": "stretch",
              "style": {
                "gap": "12px",
                "overflow": "visible"
              }
            },
            "meta": {
              "name": "heroFacts"
            },
            "position": {
              "grow": 0,
              "shrink": 0,
              "basis": "auto"
            },
            "children": [
              {
                "version": 0,
                "type": "ia.display.label",
                "props": {
                  "text": "License",
                  "style": {
                    "classes": "sg/statusGood"
                  }
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "expr",
                      "config": {
                        "expression": "\"License: \" + {[System]Gateway/LicenseState}"
                      }
                    }
                  }
                },
                "meta": {
                  "name": "licenseState"
                },
                "position": {
                  "grow": 0,
                  "shrink": 0,
                  "basis": "auto"
                }
              },
              {
                "version": 0,
                "type": "ia.display.label",
                "props": {
                  "text": "Role",
                  "style": {
                    "classes": "sg/statusGood"
                  }
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "expr",
                      "config": {
                        "expression": "\"Role: \" + {[System]Gateway/Redundancy/Role}"
                      }
                    }
                  }
                },
                "meta": {
                  "name": "redundancyRole"
                },
                "position": {
                  "grow": 0,
                  "shrink": 0,
                  "basis": "auto"
                }
              },
              {
                "version": 0,
                "type": "ia.display.label",
                "props": {
                  "text": "Uptime",
                  "style": {
                    "classes": "sg/statusGood"
                  }
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "type": "expr",
                      "config": {
                        "expression": "\"Uptime: \" + toStr(floor({[System]Gateway/UptimeSeconds} / 86400)) + \"d \" + toStr(floor(({[System]Gateway/UptimeSeconds} - (floor({[System]Gateway/UptimeSeconds} / 86400) * 86400)) / 3600)) + \"h\""
                      }
                    }
                  }
                },
                "meta": {
                  "name": "uptime"
                },
                "position": {
                  "grow": 0,
                  "shrink": 0,
                  "basis": "auto"
                }
              }
            ]
          },
          {
            "version": 0,
            "type": "ia.display.label",
            "props": {
              "text": "Live gateway health metrics from the System tag provider. These cards are intentionally reusable so future Perspective pages can use the same visual language.",
              "style": {
                "classes": "sg/muted",
                "fontSize": "1.05rem",
                "maxWidth": "760px"
              }
            },
            "meta": {
              "name": "heroCopy"
            },
            "position": {
              "grow": 0,
              "shrink": 0,
              "basis": "auto"
            }
          }
        ]
      },
      {
        "version": 0,
        "type": "ia.container.flex",
        "props": {
          "direction": "row",
          "wrap": "wrap",
          "justify": "flex-start",
          "alignItems": "stretch",
          "alignContent": "stretch",
          "style": {
            "gap": "18px",
            "overflow": "visible"
          }
        },
        "meta": {
          "name": "metricGrid"
        },
        "position": {
          "grow": 1,
          "shrink": 1,
          "basis": "auto"
        },
        "children": [
          {
            "version": 0,
            "type": "ia.display.view",
            "props": {
              "path": "Shared/MetricCard",
              "params": {
                "label": "CPU usage",
                "value": "Unavailable",
                "unit": "%",
                "status": "Good",
                "helperText": "JVM-reported gateway CPU utilization",
                "progress": 0
              },
              "style": {
                "height": "190px"
              }
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "numberFormat({[System]Gateway/Performance/CPU Usage}, \"0.0\")"
                  }
                }
              },
              "props.params.progress": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{[System]Gateway/Performance/CPU Usage}"
                  }
                }
              },
              "props.params.status": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({[System]Gateway/Performance/CPU Usage} >= 90, \"Danger\", if({[System]Gateway/Performance/CPU Usage} >= 70, \"Warning\", \"Good\"))"
                  }
                }
              }
            },
            "meta": {
              "name": "cpuCard"
            },
            "position": {
              "grow": 1,
              "shrink": 1,
              "basis": "320px"
            }
          },
          {
            "version": 0,
            "type": "ia.display.view",
            "props": {
              "path": "Shared/MetricCard",
              "params": {
                "label": "Memory utilization",
                "value": "Unavailable",
                "unit": "%",
                "status": "Good",
                "helperText": "Current memory usage divided by max memory",
                "progress": 0
              },
              "style": {
                "height": "190px"
              }
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "numberFormat({[System]Gateway/Performance/Memory Utilization}, \"0.0\")"
                  }
                }
              },
              "props.params.progress": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{[System]Gateway/Performance/Memory Utilization}"
                  }
                }
              },
              "props.params.status": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({[System]Gateway/Performance/Memory Utilization} >= 90, \"Danger\", if({[System]Gateway/Performance/Memory Utilization} >= 70, \"Warning\", \"Good\"))"
                  }
                }
              }
            },
            "meta": {
              "name": "memoryUtilizationCard"
            },
            "position": {
              "grow": 1,
              "shrink": 1,
              "basis": "320px"
            }
          },
          {
            "version": 0,
            "type": "ia.display.view",
            "props": {
              "path": "Shared/MetricCard",
              "params": {
                "label": "Memory used",
                "value": "Unavailable",
                "unit": " MB",
                "status": "Good",
                "helperText": "Gateway memory currently in use",
                "progress": 0
              },
              "style": {
                "height": "190px"
              }
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "numberFormat({[System]Gateway/Performance/Memory Usage} / 1048576, \"0\")"
                  }
                }
              },
              "props.params.progress": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{[System]Gateway/Performance/Memory Utilization}"
                  }
                }
              }
            },
            "meta": {
              "name": "memoryUsedCard"
            },
            "position": {
              "grow": 1,
              "shrink": 1,
              "basis": "320px"
            }
          },
          {
            "version": 0,
            "type": "ia.display.view",
            "props": {
              "path": "Shared/MetricCard",
              "params": {
                "label": "Max memory",
                "value": "Unavailable",
                "unit": " MB",
                "status": "Good",
                "helperText": "Configured JVM maximum memory",
                "progress": 100
              },
              "style": {
                "height": "190px"
              }
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "numberFormat({[System]Gateway/Performance/Max Memory} / 1048576, \"0\")"
                  }
                }
              }
            },
            "meta": {
              "name": "maxMemoryCard"
            },
            "position": {
              "grow": 1,
              "shrink": 1,
              "basis": "320px"
            }
          },
          {
            "version": 0,
            "type": "ia.display.view",
            "props": {
              "path": "Shared/MetricCard",
              "params": {
                "label": "Disk utilization",
                "value": "Unavailable",
                "unit": "%",
                "status": "Good",
                "helperText": "Percentage of hard disk currently in use",
                "progress": 0
              },
              "style": {
                "height": "190px"
              }
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "numberFormat({[System]Gateway/Performance/Disk Utilization}, \"0.0\")"
                  }
                }
              },
              "props.params.progress": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "{[System]Gateway/Performance/Disk Utilization}"
                  }
                }
              },
              "props.params.status": {
                "binding": {
                  "type": "expr",
                  "config": {
                    "expression": "if({[System]Gateway/Performance/Disk Utilization} >= 90, \"Danger\", if({[System]Gateway/Performance/Disk Utilization} >= 70, \"Warning\", \"Good\"))"
                  }
                }
              }
            },
            "meta": {
              "name": "diskCard"
            },
            "position": {
              "grow": 1,
              "shrink": 1,
              "basis": "320px"
            }
          },
          {
            "version": 0,
            "type": "ia.display.view",
            "props": {
              "path": "Shared/MetricCard",
              "params": {
                "label": "Gateway sessions",
                "value": "Unavailable",
                "unit": "",
                "status": "Good",
                "helperText": "Active sessions on this gateway",
                "progress": 0
              },
              "style": {
                "height": "190px"
              }
            },
            "propConfig": {
              "props.params.value": {
                "binding": {
                  "type": "tag",
                  "config": {
                    "mode": "direct",
                    "tagPath": "[System]Gateway/Sessions/SessionCount",
                    "fallbackDelay": 2.5,
                    "publishInitial": true
                  }
                }
              }
            },
            "meta": {
              "name": "sessionsCard"
            },
            "position": {
              "grow": 1,
              "shrink": 1,
              "basis": "320px"
            }
          }
        ]
      }
    ]
  }
}
