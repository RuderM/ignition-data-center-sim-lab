{
  "custom": {
    "key": ""
  },
  "params": {
    "icon": "material/face",
    "items": [
      {
        "instancePosition": {},
        "instanceStyle": {
          "classes": "",
          "color": ""
        },
        "label": "Link 1",
        "target": "/exchange/responsive-nav/page/brown"
      },
      {
        "instancePosition": {},
        "instanceStyle": {
          "classes": "",
          "color": ""
        },
        "label": "Link 2",
        "target": "/exchange/responsive-nav/page/red"
      }
    ],
    "label": "Label",
    "target": ""
  },
  "propConfig": {
    "custom.key": {
      "binding": {
        "config": {
          "path": "page.props.path"
        },
        "transforms": [
          {
            "code": "\tif value \u003d\u003d self.view.params.target:\n\t\treturn \"nav-section-open \"\n\telif value.split(\"/\")[1] \u003d\u003d self.view.params.label.lower().replace(\" \",\"-\"):\n\t\treturn \"nav-section-open \"\n\telse:\n\t\treturn \"\"",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "params.icon": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.items": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.label": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.target": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 250,
      "width": 250
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Nav Link"
        },
        "position": {
          "basis": "40px",
          "shrink": 0
        },
        "propConfig": {
          "props.params.icon": {
            "binding": {
              "config": {
                "path": "view.params.icon"
              },
              "type": "property"
            }
          },
          "props.params.label": {
            "binding": {
              "config": {
                "path": "view.params.label"
              },
              "type": "property"
            }
          },
          "props.params.showArrow": {
            "binding": {
              "config": {
                "expression": "len({view.params.items}) \u003e 0"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "params": {
            "target": ""
          },
          "path": "Exchange/Responsive Nav/Nav Link"
        },
        "type": "ia.display.view"
      },
      {
        "meta": {
          "name": "FlexRepeater"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "meta.domId": {
            "binding": {
              "config": {
                "expression": "concat(\"nav-section-repeater-\",{view.params.index})"
              },
              "type": "expr"
            }
          },
          "position.display": {
            "binding": {
              "config": {
                "expression": "len({this.props.instances})\u003e0"
              },
              "type": "expr"
            }
          },
          "props.instances": {
            "binding": {
              "config": {
                "path": "view.params.items"
              },
              "transforms": [
                {
                  "code": "\tjson \u003d system.util.jsonDecode(system.util.jsonEncode(value))\n\treturn json",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "direction": "column",
          "elementPosition": {
            "basis": "auto",
            "grow": 0,
            "shrink": 0
          },
          "elementStyle": {
            "height": "var(--nav-link-height)"
          },
          "path": "Exchange/Responsive Nav/Nav Link",
          "style": {
            "classes": "nav-repeater",
            "gap": "5px",
            "overflow": "hidden"
          },
          "useDefaultViewHeight": false,
          "useDefaultViewWidth": false
        },
        "type": "ia.display.flex-repeater"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.classes": {
        "binding": {
          "config": {
            "expression": "concat(\"nav-section \",\r\n{view.custom.key}\r\n)"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "direction": "column",
      "style": {
        "overflow": "hidden"
      }
    },
    "type": "ia.container.flex"
  }
}