                  "code": "\t\"\"\"\n\tReturns an html image element with embedded javascript for adding event listeners to navigation elements\n\t\"\"\"\n\tjs \u003d \"\"\"\n\t\u003cimg style\u003d\u0027display:none\u0027 src\u003d\u0027data:image/gif;base64,R0lGODlhAQABAIAAAP///wAAACH5BAEAAAAALAAAAAABAAEAAAICRAEAOw\u003d\u003d\u0027 onload\u003d\\\"\n\nconst view \u003d [...window.__client.page.views._data.values()].find(view \u003d\u003e view.value.mountPath \u003d\u003d this.parentNode.parentNode.parentNode.getAttributeNode(\u0027data-component-path\u0027).value.split(\u0027.\u0027)[0]).value; \nconst openByDefault \u003d view.params.read(\u0027openByDefault\u0027);\nvar breakpointSmall \u003d parseInt(getComputedStyle(document.documentElement).getPropertyValue(\u0027--breakpoint-small\u0027));\nvar breakpointMedium \u003d parseInt(getComputedStyle(document.documentElement).getPropertyValue(\u0027--breakpoint-medium\u0027));\nvar nav \u003d document.querySelector(\u0027#nav\u0027);\nvar navButtonOpen \u003d document.querySelector(\u0027#navButtonOpen\u0027);\nvar navButtonClosed \u003d document.querySelector(\u0027#navButtonClosed\u0027);\nvar navSections \u003d nav.querySelectorAll(\u0027.psc-nav-section\u0027);\nfunction updateNavWidth() {\n    var viewportWidth \u003d window.innerWidth;\n    var root \u003d document.documentElement;\n    var computedStyle \u003d getComputedStyle(root);\n    var navWidthClosed \u003d computedStyle.getPropertyValue(\u0027--nav-closed-width\u0027);\n    var navWidthOpen \u003d computedStyle.getPropertyValue(\u0027--nav-open-width\u0027);\n    var isNavOpen \u003d nav.classList.contains(\u0027psc-nav-open\u0027);\n    if (viewportWidth \u003e breakpointSmall) {\n        root.style.setProperty(\u0027--nav-width\u0027, isNavOpen ? navWidthOpen : navWidthClosed);\n    }\n}\nfunction closeNav() {\n    nav.classList.remove(\u0027psc-nav-open\u0027);\n    nav.classList.remove(\u0027psc-nav-open-locked\u0027);\n    navButtonClosed.style