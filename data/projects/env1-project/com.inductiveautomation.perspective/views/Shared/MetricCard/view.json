{
  "custom": {},
  "params": {
    "helperText": "",
    "label": "Metric",
    "progress": 0,
    "status": "Good",
    "unit": "",
    "value": "Unavailable"
  },
  "propConfig": {
    "params.helperText": {
      "paramDirection": "input"
    },
    "params.label": {
      "paramDirection": "input"
    },
    "params.progress": {
      "paramDirection": "input"
    },
    "params.status": {
      "paramDirection": "input"
    },
    "params.unit": {
      "paramDirection": "input"
    },
    "params.value": {
      "paramDirection": "input"
    }
  },
  "props": {
    "defaultSize": {
      "height": 190,
      "width": 320
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "label"
            },
            "position": {
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "{view.params.label}"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "sg/eyebrow",
                "overflow": "hidden",
                "textOverflow": "ellipsis",
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "status"
            },
            "position": {
              "display": false,
              "shrink": 0
            },
            "propConfig": {
              "props.style.classes": {
                "binding": {
                  "config": {
                    "expression": "if({view.params.status} \u003d \"Danger\", \"sg/statusDanger\", if({view.params.status} \u003d \"Warning\", \"sg/statusWarning\", \"sg/statusGood\"))"
                  },
                  "type": "expr"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "expression": "{view.params.status}"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "whiteSpace": "nowrap"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "cardHeader"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "justify": "space-between",
          "style": {
            "gap": "12px",
            "overflow": "visible"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "value"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "toStr({view.params.value}) + toStr({view.params.unit})"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "sg/metricValue",
            "overflow": "hidden",
            "textOverflow": "ellipsis",
            "whiteSpace": "nowrap"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "progress"
        },
        "position": {
          "basis": "10px",
          "shrink": 0
        },
        "propConfig": {
          "props.value": {
            "binding": {
              "config": {
                "expression": "{view.params.progress}"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "bar": {
            "color": "#2f80ed"
          },
          "style": {
            "height": "10px"
          },
          "track": {
            "color": "#d9e2ef"
          }
        },
        "type": "ia.display.progress"
      },
      {
        "meta": {
          "name": "helperText"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "{view.params.helperText}"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "sg/muted",
            "fontSize": "0.9rem",
            "overflow": "hidden",
            "textOverflow": "ellipsis",
            "whiteSpace": "nowrap"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "metricCard"
    },
    "props": {
      "direction": "column",
      "justify": "space-between",
      "style": {
        "classes": "sg/metricCard",
        "gap": "14px",
        "height": "100%",
        "overflow": "hidden"
      }
    },
    "type": "ia.container.flex"
  }
}