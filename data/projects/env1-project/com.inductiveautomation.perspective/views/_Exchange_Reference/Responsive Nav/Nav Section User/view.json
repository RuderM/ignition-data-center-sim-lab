{
  "custom": {
    "emptyItems": [],
    "isLoggedIn": true,
    "items": [
      {},
      {}
    ],
    "loggedInItems": [
      {},
      {}
    ]
  },
  "params": {
    "icon": "material/account_circle",
    "items": [],
    "label": "Log in",
    "showArrow": false,
    "target": ""
  },
  "propConfig": {
    "custom.emptyItems": {
      "persistent": true
    },
    "custom.isLoggedIn": {
      "binding": {
        "config": {
          "expression": "{session.props.auth.user.userName} !\u003d null"
        },
        "type": "expr"
      },
      "persistent": true
    },
    "custom.items": {
      "binding": {
        "config": {
          "expression": "if({view.custom.isLoggedIn},{view.custom.loggedInItems},{view.custom.emptyItems})"
        },
        "type": "expr"
      },
      "persistent": true
    },
    "custom.loggedInItems": {
      "persistent": true
    },
    "params.icon": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.items": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.label": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.showArrow": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.target": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 250,
      "width": 250
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tif not self.view.custom.isLoggedIn:\n\t\tsystem.perspective.login()"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Nav Link"
        },
        "position": {
          "basis": "40px",
          "shrink": 0
        },
        "propConfig": {
          "props.params.icon": {
            "binding": {
              "config": {
                "expression": "if({view.custom.isLoggedIn},\"material/account_circle\",\"material/person\")"
              },
              "type": "expr"
            }
          },
          "props.params.label": {
            "binding": {
              "config": {
                "expression": "if({view.custom.isLoggedIn},{session.props.auth.user.userName},\"Log in\")"
              },
              "type": "expr"
            }
          },
          "props.params.showArrow": {
            "binding": {
              "config": {
                "path": "view.params.showArrow"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "params": {
            "index": 0,
            "isLink": true,
            "target": ""
          },
          "path": "Exchange/Responsive Nav/Nav Link"
        },
        "type": "ia.display.view"
      },
      {
        "children": [
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tsystem.perspective.logout()"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "Logout"
            },
            "position": {
              "basis": "40px",
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "expression": "!{session.props.auth.authenticated}\r\n\u0026\u0026 {session.props.auth.idp} !\u003d null "
                  },
                  "enabled": false,
                  "type": "expr"
                }
              }
            },
            "props": {
              "params": {
                "icon": "material/login",
                "index": 0,
                "isLink": true,
                "label": "Logout",
                "parentIndex": 0,
                "showArrow": false,
                "target": ""
              },
              "path": "Exchange/Responsive Nav/Nav Link"
            },
            "type": "ia.display.view"
          }
        ],
        "meta": {
          "name": "Links"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "{session.props.auth.authenticated}\r\n"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "direction": "column"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "props.style.classes": {
        "binding": {
          "config": {
            "expression": "if({./Links.position.display}, \"nav-section\", \"\")"
          },
          "type": "expr"
        }
      }
    },
    "props": {
      "direction": "column",
      "style": {
        "overflow": "hidden"
      }
    },
    "type": "ia.container.flex"
  }
}